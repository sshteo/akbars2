<Application x:Class="akbars.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/Main.xaml">



<Application.Resources>

        <!-- ЦВЕТА -->
        <Color x:Key="GreenMain">#19a54a</Color>
        <Color x:Key="GreenDark">#0f6b2d</Color>
        <Color x:Key="GreenBackground">#e0f4e8</Color>

        <SolidColorBrush x:Key="GreenMainBrush" Color="{StaticResource GreenMain}"/>
        <SolidColorBrush x:Key="GreenDarkBrush" Color="{StaticResource GreenDark}"/>
        <SolidColorBrush x:Key="GreenBackgroundBrush" Color="{StaticResource GreenBackground}"/>

        <!-- СТИЛЬ ОКНА -->
        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource GreenBackgroundBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinWidth" Value="700"/>
            <Setter Property="MinHeight" Value="500"/>
          
        </Style>

        <!-- КАРТОЧКА -->
        <!-- КАРТОЧКА -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Width" Value="420"/>
            <Setter Property="Padding" Value="40"/>
            <Setter Property="Background" Value="{StaticResource GreenBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GreenMainBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Gray" Direction="270" ShadowDepth="2" BlurRadius="10" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="20"/>
        </Style>


        <!-- ПАНЕЛЬ ЛОГОТИПА -->
        <Style x:Key="LogoPanel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource GreenBackgroundBrush}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="0 0 0 20"/>
        </Style>

        <!-- ЗАГОЛОВОК -->
        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Foreground" Value="{StaticResource GreenMainBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0 0 0 25"/>
        </Style>

        <!-- LABEL -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource GreenDarkBrush}"/>
            <Setter Property="Margin" Value="0 10 0 4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- TEXTBOX -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource GreenMainBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0 0 0 10"/>
        </Style>

        <!-- PASSWORDBOX -->
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource GreenMainBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
        </Style>

        <!-- КНОПКА -->
        <Style TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="{StaticResource GreenMainBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0 10 0 0"/>

            <Style.Triggers>

                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource GreenDarkBrush}"/>
                </Trigger>

            </Style.Triggers>

        </Style>

    </Application.Resources>

</Application>