<Window x:Class="akbars.Views.Dispatcher.EditProfileDispetcher"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование профиля"
        Height="500"
        Width="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Редактирование профиля"
                   FontSize="26"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,25"/>

        <!-- Форма -->
        <Border Grid.Row="1"
                Padding="25"
                CornerRadius="10"
                BorderBrush="#ddd"
                BorderThickness="1">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Фамилия:" VerticalAlignment="Center"/>
                <TextBox x:Name="LastNameBox" Grid.Column="1"/>

                <TextBlock Text="Имя:" Grid.Row="1" VerticalAlignment="Center"/>
                <TextBox x:Name="FirstNameBox" Grid.Row="1" Grid.Column="1"/>

                <TextBlock Text="Отчество:" Grid.Row="2" VerticalAlignment="Center"/>
                <TextBox x:Name="MiddleNameBox" Grid.Row="2" Grid.Column="1"/>

                <TextBlock Text="Email:" Grid.Row="3" VerticalAlignment="Center"/>
                <TextBox x:Name="EmailBox" Grid.Row="3" Grid.Column="1"/>

                <TextBlock Text="Телефон:" Grid.Row="4" VerticalAlignment="Center"/>
                <TextBox x:Name="PhoneBox" Grid.Row="4" Grid.Column="1"/>

            </Grid>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

            <Button Content="Сохранить"
                    Width="140"
                    Height="40"
                    Margin="0,10,10,0"
                    Click="Save_Click"/>

            <Button Content="Отмена"
                    Width="120"
                    Height="40"
                    Click="Cancel_Click"/>

        </StackPanel>

    </Grid>

</Window>