<Window x:Class="akbars.Views.Dispatcher.EditProfileDispetcher"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Профиль пользователя"
        Width="760"
        Height="620"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="Профиль пользователя" Style="{StaticResource TitleText}" Margin="0,0,0,8"/>
            <TextBlock Text="Обновите контактные данные и отдел. Роль и логин управляются централизованно." Style="{StaticResource SubtitleText}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="Фамилия" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="LastNameBox"/>

                    <TextBlock Text="Имя" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="FirstNameBox"/>

                    <TextBlock Text="Отчество" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="MiddleNameBox"/>

                    <TextBlock Text="Отдел" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="DepartmentBox"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Text="Email" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="EmailBox"/>

                    <TextBlock Text="Телефон" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="PhoneBox"/>

                    <TextBlock Text="Справка" Style="{StaticResource FieldLabelStyle}"/>
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="14" Padding="14">
                        <TextBlock Text="После сохранения актуальные данные будут использованы на dashboard и в очередях заявок." Style="{StaticResource SubtitleText}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Отмена" Width="140" Click="Cancel_Click"/>
            <Button Content="Сохранить профиль" Width="180" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
