<Window x:Class="akbars.Views.Dispatcher.TicketsDispatcher"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:akbars.Views.Dispatcher"
        mc:Ignorable="d"
        Title="Заявки"
        Height="750" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- Фильтры -->
            <RowDefinition Height="*"/>
            <!-- Таблица -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопки -->
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="📋 Заявки"
                   FontSize="28" FontWeight="Bold"
                   Margin="0,0,0,30"
                   HorizontalAlignment="Center"/>

        <!-- Фильтры -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    Margin="0,0,0,25"
                    HorizontalAlignment="Left">

            <StackPanel Orientation="Vertical" Margin="0,0,25,0">
                <TextBlock Text="Статус:" FontSize="14" Margin="0,0,0,5"/>
                <ComboBox x:Name="StatusFilter" Width="160" Height="35"
                          Margin="0,0,0,0"
                          SelectionChanged="FilterChanged"/>
            </StackPanel>

            <StackPanel Orientation="Vertical">
                <TextBlock Text="Приоритет:" FontSize="14" Margin="0,0,0,5"/>
                <ComboBox x:Name="PriorityFilter" Width="160" Height="35"
                          SelectionChanged="FilterChanged"/>
            </StackPanel>

        </StackPanel>

        <!-- Таблица -->
        <DataGrid x:Name="TicketsGrid"
                  Grid.Row="2"
                  Margin="0,0,0,25"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  RowHeight="50"
                  FontSize="15"
                  Foreground="#0a3d2c"
                  GridLinesVisibility="Horizontal">

            <DataGrid.Resources>
                <!-- Цвет статусов -->
                <Style TargetType="TextBlock" x:Key="StatusStyle">
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Status}" Value="Новая">
                            <Setter Property="Foreground" Value="DodgerBlue"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="В работе">
                            <Setter Property="Foreground" Value="DarkOrange"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="Выполнена">
                            <Setter Property="Foreground" Value="Green"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="Отклонена">
                            <Setter Property="Foreground" Value="Red"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt}" Width="150"/>
                <DataGridTextColumn Header="Последнее изменение" Binding="{Binding UpdatedAt}" Width="170"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="2*"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="160"/>
                <DataGridTextColumn Header="Приоритет" Binding="{Binding Priority}" Width="120"/>

                <DataGridTemplateColumn Header="Статус" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Status}" Style="{StaticResource StatusStyle}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Подробнее" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="📋 Подробнее" Width="95" Height="40" 
                                    Click="Details_Click" Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Назначить" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="👤 Назначить" Width="120" Height="40" 
                                    Click="AssignExecutor_Click" Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Кнопка Назад слева -->
            <Button Grid.Column="0" 
                    Content="← Назад" 
                    Width="130" Height="NaN"
                    Margin="20,20,0,10"
                    Click="Back_Click"/>

            <!-- Кнопки справа горизонтально -->
            <StackPanel Grid.Column="2" 
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,10,15,10">

                <Button Content="➕ Создать заявку" 
                        Width="160" Height="40"
                        Margin="0,10,10,0"
                        Click="CreateTicket_Click"/>

                <Button Content="🗑 Удалить"
                        Width="140"
                        Height="40"
                        Background="Red"
                        Foreground="White"
                        Click="DeleteTicket_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
