<Window x:Class="akbars.Views.Dispatcher.TicketsDispatcher"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Очередь заявок"
        Width="1320"
        Height="840"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="Очередь заявок" Style="{StaticResource TitleText}" Margin="0,0,0,8"/>
            <TextBlock Text="Назначайте исполнителей, проверяйте детали и отслеживайте проблемные заявки." Style="{StaticResource SubtitleText}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="Статус" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="StatusFilter"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="12,0">
                    <TextBlock Text="Приоритет" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="PriorityFilter"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="12,0">
                    <TextBlock Text="Поиск" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="SearchBox"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="12,0,0,0">
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Применить" Width="120" Click="FilterChanged"/>
                    <Button Content="Обновить" Width="120" Click="Refresh_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <DataGrid x:Name="TicketsGrid" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="65"/>
                    <DataGridTextColumn Header="Создана" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                    <DataGridTextColumn Header="Обновлена" Binding="{Binding UpdatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                    <DataGridTextColumn Header="Описание" Binding="{Binding ShortDescription}" Width="2*"/>
                    <DataGridTextColumn Header="Автор" Binding="{Binding AuthorName}" Width="170"/>
                    <DataGridTextColumn Header="Исполнитель" Binding="{Binding AssigneeName}" Width="170"/>
                    <DataGridTextColumn Header="Приоритет" Binding="{Binding PriorityName}" Width="130"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="130"/>
                    <DataGridTemplateColumn Header="Карточка" Width="115">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Открыть" Tag="{Binding Id}" Width="90" Click="Details_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Назначить" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Назначить" Tag="{Binding Id}" Width="100" Click="AssignExecutor_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Закрыть" Width="120" HorizontalAlignment="Left" Click="Back_Click"/>
            <TextBlock Grid.Column="1" Text="Используйте назначение повторно для reassignment." VerticalAlignment="Center" Style="{StaticResource SubtitleText}"/>
        </Grid>
    </Grid>
</Window>
