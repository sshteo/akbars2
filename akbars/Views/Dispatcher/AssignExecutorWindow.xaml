<Window x:Class="akbars.Views.Dispatcher.AssignExecutorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Назначение исполнителя"
        Width="540"
        Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="Назначение исполнителя" Style="{StaticResource TitleText}" Margin="0,0,0,8"/>
            <TextBlock Text="Выберите сотрудника с ролью исполнителя. Повторное назначение выполняет reassignment." Style="{StaticResource SubtitleText}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="18">
            <StackPanel>
                <TextBlock Text="Исполнитель" Style="{StaticResource FieldLabelStyle}"/>
                <ComboBox x:Name="ExecutorCombo" DisplayMemberPath="FullName" SelectedValuePath="Id"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Отмена" Width="120" Click="Cancel_Click"/>
            <Button Content="Назначить" Width="150" Click="Assign_Click"/>
        </StackPanel>
    </Grid>
</Window>
