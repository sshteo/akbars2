<Window x:Class="akbars.Views.Dispatcher.MainDispatcher"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ак Барс Мед | Диспетчер"
        Width="1280"
        Height="840"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock x:Name="HelloText" Style="{StaticResource TitleText}" Margin="0,0,0,8"/>
                <TextBlock Text="Оперативный контур: triage, очереди, назначение исполнителей и мониторинг просрочки." Style="{StaticResource SubtitleText}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Профиль" Width="120" Click="EditProfile_Click"/>
                <Button Content="Очередь заявок" Width="160" Click="AssignTickets_Click"/>
                <Button Style="{StaticResource DangerButtonStyle}" Content="Выйти" Width="120" Click="Logout_Click"/>
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="5" Margin="0,20,0,16">
            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0">
                <StackPanel><TextBlock Text="Всего" Style="{StaticResource SubtitleText}"/><TextBlock x:Name="TotalTicketsText" FontSize="30" FontWeight="Bold"/></StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0">
                <StackPanel><TextBlock Text="Новые" Style="{StaticResource SubtitleText}"/><TextBlock x:Name="NewTicketsText" FontSize="30" FontWeight="Bold"/></StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0">
                <StackPanel><TextBlock Text="В работе" Style="{StaticResource SubtitleText}"/><TextBlock x:Name="InProgressTicketsText" FontSize="30" FontWeight="Bold"/></StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0">
                <StackPanel><TextBlock Text="Выполнено" Style="{StaticResource SubtitleText}"/><TextBlock x:Name="CompletedTicketsText" FontSize="30" FontWeight="Bold"/></StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}">
                <StackPanel><TextBlock Text="SLA риск" Style="{StaticResource SubtitleText}"/><TextBlock x:Name="OverdueTicketsText" FontSize="30" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/></StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,18,0">
                <StackPanel>
                    <TextBlock Text="Операционный обзор" Style="{StaticResource SectionTitleText}"/>
                    <TextBlock Text="Используйте очередь заявок для назначения исполнителей и контроля статусов. Ниже — два каталога для быстрого поиска сотрудников и исполнителей." Style="{StaticResource SubtitleText}" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Сотрудники" Width="150" Click="Employees_Click"/>
                        <Button Content="Исполнители" Width="150" Click="Workers_Click"/>
                    </StackPanel>
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="14" Padding="16" Margin="0,10,0,0">
                        <TextBlock Text="Подсказка: SLA риск рассчитывается по `created_at + priorities.sla_hours` для незакрытых заявок."/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Диспетчерские обязанности" Style="{StaticResource SectionTitleText}"/>
                    <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="14" Padding="14" Margin="0,0,0,12">
                        <TextBlock Text="• сортировать входящий поток&#x0a;• назначать правильного исполнителя&#x0a;• снижать просрочку&#x0a;• держать профиль и контакты в актуальном состоянии"/>
                    </Border>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Обновить статистику" Width="180" Click="Refresh_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
