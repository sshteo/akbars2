<Window x:Class="akbars.Views.Dispatcher.WorkersDispetcher"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:akbars.Views.Dispatcher"
        mc:Ignorable="d"
        Title="Исполнители"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="25">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Исполнители"
                   FontSize="28"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Таблица сотрудников -->
        <DataGrid x:Name="EmployeesGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  RowHeight="60"
                  FontSize="15"
                  Margin="0,0,0,20">

            <DataGrid.Columns>

                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>

                <DataGridTextColumn Header="Фамилия"
                                    Binding="{Binding LastName}"
                                    Width="120"/>

                <DataGridTextColumn Header="Имя"
                                    Binding="{Binding FirstName}"
                                    Width="120"/>

                <DataGridTextColumn Header="Email"
                                    Binding="{Binding Email}"
                                    Width="200"/>

                <DataGridTextColumn Header="Телефон"
                                    Binding="{Binding Phone}"
                                    Width="150"/>

                <DataGridTextColumn Header="Отдел"
                                    Binding="{Binding Department}"
                                    Width="150"/>

                <DataGridTextColumn Header="Роль"
                                    Binding="{Binding Role}"
                                    Width="140"/>

                <!-- Кнопка -->


            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Назад -->
            <Button Content="← Назад"
                    Width="120"
                    Height="35"
                    Click="Back_Click" Margin="0,10,0,0" VerticalAlignment="Top"/>

            <!-- Справа -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal">





            </StackPanel>

        </Grid>

    </Grid>
</Window>