<Window x:Class="akbars.Views.Dispatcher.WorkersDispetcher"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Исполнители"
        Width="1180"
        Height="760"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="Исполнители" Style="{StaticResource TitleText}" Margin="0,0,0,8"/>
            <TextBlock Text="Каталог исполнителей для назначения и reassignment." Style="{StaticResource SubtitleText}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <DataGrid x:Name="EmployeesGrid" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="220"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="160"/>
                    <DataGridTextColumn Header="Отдел" Binding="{Binding Department}" Width="180"/>
                    <DataGridTextColumn Header="Роль" Binding="{Binding RoleName}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Button Grid.Row="2" Style="{StaticResource SecondaryButtonStyle}" Content="Закрыть" Width="120" HorizontalAlignment="Left" Click="Back_Click"/>
    </Grid>
</Window>
