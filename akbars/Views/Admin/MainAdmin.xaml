<Window x:Class="akbars.Views.Admin.MainAdmin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ак Барс Мед | Администрирование"
        Width="1340"
        Height="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock x:Name="HelloText" Style="{StaticResource TitleText}" Margin="0,0,0,8"/>
                <TextBlock Text="Административный контур: роли пользователей и справочники заявок." Style="{StaticResource SubtitleText}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Обновить" Width="120" Click="Refresh_Click"/>
                <Button Style="{StaticResource DangerButtonStyle}" Content="Выйти" Width="120" Click="Logout_Click"/>
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,20,0,16">
            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Пользователей" Style="{StaticResource SubtitleText}"/><TextBlock x:Name="UsersCountText" FontSize="30" FontWeight="Bold"/></StackPanel></Border>
            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Сотрудники" Style="{StaticResource SubtitleText}"/><TextBlock x:Name="EmployeesCountText" FontSize="30" FontWeight="Bold"/></StackPanel></Border>
            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Исполнители" Style="{StaticResource SubtitleText}"/><TextBlock x:Name="ExecutorsCountText" FontSize="30" FontWeight="Bold"/></StackPanel></Border>
            <Border Style="{StaticResource MetricCardStyle}"><StackPanel><TextBlock Text="Заявки" Style="{StaticResource SubtitleText}"/><TextBlock x:Name="TicketsCountText" FontSize="30" FontWeight="Bold"/></StackPanel></Border>
        </UniformGrid>

        <TabControl Grid.Row="2">
            <TabItem Header="Пользователи">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="UsersGrid" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="220"/>
                            <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="170"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220"/>
                            <DataGridTextColumn Header="Отдел" Binding="{Binding Department}" Width="170"/>
                            <DataGridTextColumn Header="Текущая роль" Binding="{Binding RoleName}" Width="180"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <TextBlock Text="Новая роль:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="RoleSelector" Width="220" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                        <Button Content="Обновить роль выбранного пользователя" Width="280" Click="UpdateRole_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Справочники">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Приоритеты" Style="{StaticResource SectionTitleText}"/>
                            <DataGrid x:Name="PrioritiesGrid" Height="360" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="SLA (ч)" Binding="{Binding SlaHours}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="Название" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="PriorityNameBox"/>
                            <TextBlock Text="SLA часов" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="PrioritySlaBox"/>
                            <Button Content="Добавить приоритет" Width="170" Click="AddPriority_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0">
                        <StackPanel>
                            <TextBlock Text="Статусы" Style="{StaticResource SectionTitleText}"/>
                            <DataGrid x:Name="StatusesGrid" Height="360" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="180"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="Название" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="StatusNameBox"/>
                            <TextBlock Text="Описание" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="StatusDescriptionBox"/>
                            <Button Content="Добавить статус" Width="170" Click="AddStatus_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Типы заявок" Style="{StaticResource SectionTitleText}"/>
                            <DataGrid x:Name="TypesGrid" Height="360" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="Название" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="TypeNameBox"/>
                            <Button Content="Добавить тип" Width="170" Click="AddType_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
