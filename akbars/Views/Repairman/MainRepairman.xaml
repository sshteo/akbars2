<Window x:Class="akbars.Views.Repairman.MainRepairman"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ак Барс Мед | Исполнитель"
        Width="1280"
        Height="860"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock x:Name="HelloText" Style="{StaticResource TitleText}" Margin="0,0,0,8"/>
                <TextBlock Text="Ваш рабочий контур: взять заявку, довести до результата, зафиксировать статус и комментарий." Style="{StaticResource SubtitleText}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Профиль" Width="120" Click="EditProfile_Click"/>
                <Button Content="Обновить" Width="120" Click="Refresh_Click"/>
                <Button Style="{StaticResource DangerButtonStyle}" Content="Выйти" Width="120" Click="Logout_Click"/>
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,20,0,16">
            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Назначено" Style="{StaticResource SubtitleText}"/><TextBlock x:Name="AssignedText" FontSize="30" FontWeight="Bold"/></StackPanel></Border>
            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="В работе" Style="{StaticResource SubtitleText}"/><TextBlock x:Name="InProgressText" FontSize="30" FontWeight="Bold"/></StackPanel></Border>
            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="Завершено" Style="{StaticResource SubtitleText}"/><TextBlock x:Name="CompletedText" FontSize="30" FontWeight="Bold"/></StackPanel></Border>
            <Border Style="{StaticResource MetricCardStyle}"><StackPanel><TextBlock Text="Просрочка" Style="{StaticResource SubtitleText}"/><TextBlock x:Name="OverdueText" FontSize="30" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/></StackPanel></Border>
        </UniformGrid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <DataGrid x:Name="TicketsGrid" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="65"/>
                    <DataGridTextColumn Header="Обновлена" Binding="{Binding UpdatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                    <DataGridTextColumn Header="Описание" Binding="{Binding ShortDescription}" Width="2*"/>
                    <DataGridTextColumn Header="Автор" Binding="{Binding AuthorName}" Width="170"/>
                    <DataGridTextColumn Header="Приоритет" Binding="{Binding PriorityName}" Width="130"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="130"/>
                    <DataGridTemplateColumn Header="Карточка" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Открыть" Tag="{Binding Id}" Width="90" Click="OpenTicket_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="3" Text="Действия по статусам выполняются из карточки заявки." Style="{StaticResource SubtitleText}" VerticalAlignment="Center"/>
    </Grid>
</Window>
