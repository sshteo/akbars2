<Window x:Class="akbars.Views.Worker.CreateTicketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая заявка"
        Width="760"
        Height="620"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="Новая заявка" Style="{StaticResource TitleText}" Margin="0,0,0,8"/>
            <TextBlock Text="Сформулируйте проблему кратко, затем добавьте детали для диспетчера и исполнителя." Style="{StaticResource SubtitleText}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Краткое описание" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="ShortDescriptionBox" Grid.Row="0" Margin="0,24,0,14"/>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Подробное описание" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="DetailedDescriptionBox" Height="220" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

                <Grid Grid.Row="2" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Тип заявки" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="TypeBox" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Приоритет" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="PriorityBox" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Отмена" Width="130" Click="Cancel_Click"/>
            <Button Content="Создать заявку" Width="170" Click="Create_Click"/>
        </StackPanel>
    </Grid>
</Window>
