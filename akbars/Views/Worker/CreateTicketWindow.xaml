<Window x:Class="akbars.Views.Worker.CreateTicketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создать заявку"
        Height="500"
        Width="400"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Описание проблемы"/>
            <TextBox x:Name="ProblemBox"
                     Height="200"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"/>

            <TextBlock Margin="0,10,0,0" Text="Тип неисправности"/>
            <ComboBox x:Name="TypeBox"/>

            <TextBlock Margin="0,10,0,0" Text="Приоритет"/>
            <ComboBox x:Name="PriorityBox"/>

            <Button Content="Создать заявку"
                    Margin="0,20,0,0"
                    Height="35"
                    Click="Create_Click"/>

        </StackPanel>

    </Grid>
</Window>