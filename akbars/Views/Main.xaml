<Window x:Class="akbars.Views.Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ак Барс Мед | Service Desk"
        Width="1180"
        Height="760"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*"/>
            <ColumnDefinition Width="0.9*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource HeroPanelStyle}" Margin="0,0,18,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <Image Source="/Resources/icon.png" Height="82" HorizontalAlignment="Left" Margin="0,0,0,24"/>
                    <TextBlock Text="Внутренний сервисный центр Ак Барс Мед"
                               Foreground="White"
                               FontSize="34"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14"/>
                    <TextBlock Text="Единая точка входа для сотрудников, диспетчеров, исполнителей и администраторов."
                               Foreground="#E8FFF3"
                               FontSize="16"
                               Width="470"/>
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <Border Background="#18FFFFFF" CornerRadius="16" Padding="18" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Быстрые улучшения в этой версии" Foreground="White" FontWeight="SemiBold" FontSize="18" Margin="0,0,0,10"/>
                            <TextBlock Text="• защищённый вход и миграция legacy-паролей" Foreground="#F3FFFA" Margin="0,0,0,6"/>
                            <TextBlock Text="• role-based dashboards и единая session state" Foreground="#F3FFFA" Margin="0,0,0,6"/>
                            <TextBlock Text="• понятные очереди заявок, фильтры и детали" Foreground="#F3FFFA" Margin="0,0,0,6"/>
                            <TextBlock Text="• база для SLA, назначения и истории изменений" Foreground="#F3FFFA"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="Настройте строку подключения в App.config перед первым production-запуском."
                           Foreground="#D8FFF1"/>
            </Grid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="34">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Вход в сервисный контур" Style="{StaticResource TitleText}" Margin="0,0,0,10"/>
                    <TextBlock Text="Введите корпоративный логин и пароль. Пароль больше не сохраняется на устройстве." Style="{StaticResource SubtitleText}" Margin="0,0,0,24"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Логин" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="LoginBox"/>

                    <TextBlock Text="Пароль" Style="{StaticResource FieldLabelStyle}"/>
                    <PasswordBox x:Name="PasswordBox"/>

                    <CheckBox x:Name="RememberMeCheck"
                              Content="Запомнить только логин"
                              Margin="0,0,0,12"
                              Foreground="{StaticResource MutedInkBrush}"/>
                </StackPanel>

                <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="14" Padding="16" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Состояние системы" Style="{StaticResource SectionTitleText}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="StatusText"
                                   Text="Проверка подключения..."
                                   Foreground="{StaticResource MutedInkBrush}"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="LoginButton" Content="Войти" Width="160" Click="Login_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
